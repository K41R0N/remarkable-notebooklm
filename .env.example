# reMarkable → NotebookLM Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ---------------------------------------------------------------------------
# reMarkable Cloud
# ---------------------------------------------------------------------------
# Permanent JWT — obtained once via scripts/register_device.py
RM_DEVICE_TOKEN=

# Short-lived JWT — leave empty to auto-refresh from device token each session
RM_USER_TOKEN=

# ---------------------------------------------------------------------------
# OCR Provider (pick one, set the corresponding API key)
# ---------------------------------------------------------------------------
OCR_PROVIDER=gemini         # Options: gemini | openai | claude

GEMINI_API_KEY=             # Google AI Studio: https://aistudio.google.com/app/apikey
OPENAI_API_KEY=             # OpenAI: https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=          # Anthropic: https://console.anthropic.com/

# ---------------------------------------------------------------------------
# NotebookLM / AI backend path
# ---------------------------------------------------------------------------
# A = unofficial notebooklm-py (cookie-based, fragile — dev/prototype only)
# B = NotebookLM Enterprise API (no chat endpoint — source management only)
# C = Gemini API with document grounding (recommended for production)
NOTEBOOKLM_PATH=C

# Path A: unofficial notebooklm-py
# Run `notebooklm login` to generate this file (~/.notebooklm/storage_state.json)
NOTEBOOKLM_AUTH_JSON=

# Path B: NotebookLM Enterprise
# Find PROJECT_NUMBER at: https://console.cloud.google.com/welcome
NOTEBOOKLM_PROJECT_NUMBER=
NOTEBOOKLM_LOCATION=us-central1
NOTEBOOKLM_ENDPOINT_LOCATION=us-central1

# Path C: Gemini with GCS grounding (reuses GEMINI_API_KEY above)
# Create bucket at: https://console.cloud.google.com/storage/browser
GCS_BUCKET_NAME=

# ---------------------------------------------------------------------------
# Google Drive (used by Paths A and B for source upload intermediary)
# ---------------------------------------------------------------------------
# Download OAuth credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CREDENTIALS_JSON=credentials.json

# Auto-managed by the OAuth flow — do not edit manually
GOOGLE_TOKEN_JSON=token.json

# Optional: Google Drive folder ID to keep uploaded docs organised
GOOGLE_DRIVE_FOLDER_ID=

# ---------------------------------------------------------------------------
# State management
# ---------------------------------------------------------------------------
# SQLite database for tracking processed pages and avoiding duplicate work
STATE_DB_PATH=~/.rm_notebooklm/state.db

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json             # json (production) | text (development)
